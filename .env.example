# URL do site em produção (usado no sitemap, OG, redirect Stripe). Use a URL canônica do domínio.
# Site acessado em phoenixglobal.com.br → use https://phoenixglobal.com.br ou https://www.phoenixglobal.com.br
NEXT_PUBLIC_SITE_URL=https://phoenixglobal.com.br

# Número do WhatsApp Business com DDI, sem + (usado em todos os links wa.me).
# Brasil: 55 + DDD + número. Ex.: (85) 99448-2323 = 5585994482323
NEXT_PUBLIC_WHATSAPP_NUMBER=5585994482323

# Stripe (gateway de pagamento) — ver docs/DADOS-STRIPE-E-VERCEL.md
# Chaves em https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Analytics (fase 3)
# Defina pelo menos um:
# - NEXT_PUBLIC_GTM_ID (ex.: GTM-XXXXXXX) para Google Tag Manager
# - NEXT_PUBLIC_GA_MEASUREMENT_ID (ex.: G-XXXXXXXXXX) para GA4 direto
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
