# URL do site em produção (usado no sitemap, Open Graph e JSON-LD).
# Exemplo: https://phoenixglobalimport.com.br
NEXT_PUBLIC_SITE_URL=https://phoenixglobalimport.com.br

# Número do WhatsApp com DDI, sem + (usado em todos os links wa.me).
# Exemplo: 5585999999999
NEXT_PUBLIC_WHATSAPP_NUMBER=5585999999999

# Stripe (gateway de pagamento)
# Chave publicável: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Chave secreta (só servidor; nunca commitar a real)
STRIPE_SECRET_KEY=sk_live_...
